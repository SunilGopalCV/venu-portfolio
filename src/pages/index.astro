---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import FilmTape from "../components/FilmTape.astro";
import Legacy from "../components/Legacy.astro";
import BentoGrid from "../components/BentoGrid.astro";
import Footer from "../components/Footer.astro"; // <-- Import Footer
import { sanityClient } from "sanity:client";

const featuredGalleries = await sanityClient.fetch(`
  *[_type == "gallery" && featured == true && defined(slug.current)] | order(eventDate desc) {
    title,
    category,
    "slug": slug.current,
    "imageUrl": coverImage.secure_url
  }
`);
---

<Layout title="Venu Photography | Cinematic & Traditional Events">
  
  <Navbar />
  <Hero />

  <main class="relative z-20 bg-zinc-950 min-h-screen">
     <FilmTape />
     <Legacy />
     
     {featuredGalleries.length > 0 ? (
       <BentoGrid galleries={featuredGalleries} />
     ) : (
       <div class="py-32 text-center text-zinc-500 italic font-serif">
          Log into Sanity and toggle "Feature on Homepage" for a few galleries to see them here.
       </div>
     )}
  </main>

  <Footer /> <!-- <-- Add Footer here -->

</Layout>