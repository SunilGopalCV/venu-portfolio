---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { sanityClient } from "sanity:client";

// Fetch ALL galleries, ordered by event date
const allGalleries = await sanityClient.fetch(`
  *[_type == "gallery" && defined(slug.current)] | order(eventDate desc) {
    title,
    category,
    "slug": slug.current,
    "imageUrl": coverImage.secure_url
  }
`);
---

<Layout title="Portfolio | Venu Photography">
  
  <Navbar />

  <!-- Page Header -->
  <header class="pt-40 pb-20 px-6 bg-stone-50 dark:bg-zinc-950 text-center border-b border-stone-200 dark:border-zinc-900 transition-colors duration-300">
    <div class="max-w-4xl mx-auto">
      <p class="text-amber-600 dark:text-amber-500 text-xs tracking-[0.2em] uppercase font-semibold mb-4">
        The Archive
      </p>
      <h1 class="text-5xl md:text-7xl font-serif text-stone-900 dark:text-white tracking-tight mb-6">
        Complete <span class="italic text-stone-500 dark:text-zinc-400">Portfolio</span>
      </h1>
      <p class="text-stone-600 dark:text-zinc-400 text-lg font-light max-w-2xl mx-auto">
        A curated collection of timeless traditions, cinematic narratives, and life's most unforgettable moments.
      </p>
    </div>
  </header>

  <!-- The Full Archive Grid -->
  <main class="py-24 px-6 bg-stone-50 dark:bg-zinc-950 transition-colors duration-300 min-h-screen">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 auto-rows-[300px] gap-4 grid-flow-dense">
        {allGalleries.map((gallery, index) => {
          // Dynamic sizing for a masonry/magazine feel
          let sizeClass = "col-span-1 row-span-1";
          if (index % 7 === 0) sizeClass = "md:col-span-2 md:row-span-2";
          else if (index % 5 === 0) sizeClass = "md:col-span-2 md:row-span-1";
          else if (index % 4 === 0) sizeClass = "md:col-span-1 md:row-span-2";

          return (
            <a 
              href={`/${gallery.slug}`} 
              class={`group relative overflow-hidden rounded-sm bg-stone-200 dark:bg-zinc-900 ${sizeClass}`}
            >
              <img 
                src={gallery.imageUrl} 
                alt={gallery.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105"
                loading="lazy"
              />
              
              <!-- Gradient matches both light and dark mode effectively by using pure black for contrast -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-70 group-hover:opacity-90 transition-opacity duration-700"></div>
              
              <div class="absolute bottom-0 left-0 p-8 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                <p class="text-amber-500 text-xs tracking-[0.2em] uppercase mb-2 drop-shadow-md font-medium">
                  {gallery.category}
                </p>
                <h2 class="text-2xl font-serif text-white drop-shadow-lg leading-tight">
                  {gallery.title}
                </h2>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </main>

  <Footer />

</Layout>