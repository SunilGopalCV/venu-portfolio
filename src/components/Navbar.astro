---
// src/components/Navbar.astro
---
<header id="main-nav" class="fixed top-0 w-full z-50 bg-transparent px-6 py-6 transition-all duration-500">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    
    <a href="/" class="text-3xl font-serif text-white tracking-[0.1em] drop-shadow-md">
      VENUGOPALA
    </a>

    <div class="flex items-center gap-4 md:gap-6">
      
      <!-- Light/Dark Mode Toggle Button -->
      <button id="theme-toggle" type="button" class="text-amber-500 hover:text-amber-900 transition-colors drop-shadow-md p-2" aria-label="Toggle Dark Mode">
        <!-- Sun Icon (shows in dark mode) -->
        <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
        <!-- Moon Icon (shows in light mode) -->
        <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
      </button>

      <!-- Phone Button -->
      <a href="tel:+919876543210" class="bg-amber-600/90 hover:bg-amber-500 text-white px-5 py-2.5 rounded-sm text-xs font-semibold tracking-[0.15em] uppercase transition-all duration-300 shadow-[0_0_20px_rgba(217,119,6,0.4)] hover:shadow-[0_0_30px_rgba(217,119,6,0.6)] flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
        <span class="hidden md:block">+91 9632857866</span>
      </a>
      
    </div>
  </div>
</header>

<script>
  // 1. Scroll Effect Logic
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      // We use dark backgrounds for the floating nav to ensure readability over content
      nav.classList.add('bg-white/90', 'dark:bg-zinc-950/95', 'backdrop-blur-md', 'py-4', 'shadow-lg');
      nav.classList.remove('bg-transparent', 'py-6');
      
      // Change logo text color based on scroll to contrast with light nav
      nav.querySelector('a').classList.remove('text-white');
      nav.querySelector('a').classList.add('text-stone-900', 'dark:text-white');
    } else {
      nav.classList.add('bg-transparent', 'py-6');
      nav.classList.remove('bg-white/90', 'dark:bg-zinc-950/95', 'backdrop-blur-md', 'py-4', 'shadow-lg');
      
      // Reset logo text color to white when transparent over the dark Hero image
      nav.querySelector('a').classList.add('text-white');
      nav.querySelector('a').classList.remove('text-stone-900', 'dark:text-white');
    }
  });

  // 2. Theme Toggle Logic
  const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
  const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
  const themeToggleBtn = document.getElementById('theme-toggle');

  // Change the icons inside the button based on previous settings
  if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      themeToggleLightIcon.classList.remove('hidden');
  } else {
      themeToggleDarkIcon.classList.remove('hidden');
  }

  themeToggleBtn.addEventListener('click', function() {
      // Toggle icons inside button
      themeToggleDarkIcon.classList.toggle('hidden');
      themeToggleLightIcon.classList.toggle('hidden');

      // If is dark mode, switch to light
      if (document.documentElement.classList.contains('dark')) {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('theme', 'light');
      } else {
          // If is light mode, switch to dark
          document.documentElement.classList.add('dark');
          localStorage.setItem('theme', 'dark');
      }
  });
</script>