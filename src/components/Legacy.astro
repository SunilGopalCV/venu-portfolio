---
const photographerImage = "https://maroonvows.com/wp-content/uploads/2025/08/1.-Praveen-Founder.jpg";

const tools = [
  {
    name: "Sony Alpha IV",
    role: "Cinematic Video",
    image: "https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=800&auto=format&fit=crop"
  },
  {
    name: "Nikon D850",
    role: "Traditional Detail",
    image: "https://www.nikon.co.in/media/wysiwyg/DSLRD850/marketing-hero-850.jpg"
  },
  {
    name: "Adobe Master Suite",
    role: "Flawless Editing",
    image: "https://images.unsplash.com/photo-1626785774573-4b799315345d?q=80&w=800&auto=format&fit=crop"
  },
  {
    name: "Edius",
    role: "Video Workflow",
    image: "https://images.unsplash.com/photo-1574717024653-61fd2cf4d44d?q=80&w=800&auto=format&fit=crop"
  }
];
---
<section class="py-32 px-6 bg-stone-50 dark:bg-zinc-950 relative z-20 border-b border-stone-200 dark:border-zinc-900/50 overflow-hidden">
  <div class="max-w-6xl mx-auto">
    
    <!-- About Me Split Section -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center mb-32">
      
      <!-- Left Column: The Portrait -->
      <div class="lg:col-span-5 relative group">
        <!-- Decorative Gold Offset Frame -->
        <div class="absolute -inset-4 bg-amber-900/10 border border-amber-700/30 translate-x-4 translate-y-4 rounded-sm transition-transform duration-700 group-hover:translate-x-6 group-hover:translate-y-6"></div>
        
        <!-- Image Container -->
        <div class="relative aspect-[3/4] overflow-hidden rounded-sm bg-stone-100 dark:bg-zinc-900 shadow-2xl">
          <img 
            src={photographerImage} 
            alt="Venu - Master Photographer"
            class="absolute inset-0 w-full h-full object-cover grayscale-[40%] transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105"
          />
          <!-- Subtle dark gradient so it blends into the background -->
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-transparent to-transparent opacity-80"></div>
        </div>
      </div>

      <!-- Right Column: The Story -->
      <div class="lg:col-span-7 space-y-8 relative">
        <div class="inline-block border border-amber-700/50 px-4 py-1.5 rounded-full mb-2">
          <p class="text-amber-500 text-xs tracking-[0.2em] uppercase font-semibold">
            The Visionary Behind the Lens
          </p>
        </div>
        
        <h2 class="text-4xl md:text-6xl font-serif text-stone-900 dark:text-white tracking-tight leading-tight">
          Two Decades of <span class="italic text-stone-600 dark:text-zinc-400">Timeless Elegance</span>
        </h2>
        
        <div class="space-y-6 text-stone-600 dark:text-zinc-400 text-lg font-light leading-relaxed">
          <p>
            For over 20 years, I have dedicated my craft to the art of authentic storytelling. Specializing in traditional marriages, grand engagements, and cultural events, my goal is to freeze fleeting emotions into eternal memories.
          </p>
          <p>
            My approach blends the vibrant authenticity of classic photography with the dynamic flow of cinematic videography. I don't just document events; I capture your legacy, the unscripted joy, and the rich colors of your most important days.
          </p>
        </div>

        <!-- Signature/Name Block -->
        <div class="pt-6 border-t border-zinc-800/80 mt-8 inline-block">
           <p class="font-serif text-3xl text-stone-900 dark:text-white italic">Venugopala</p>
           <p class="text-zinc-500 text-xs uppercase tracking-[0.2em] mt-2 font-medium">Master Photographer & Cinematographer</p>
        </div>
      </div>
      
    </div>

    <!-- The Gear / Tools Grid -->
    <div class="text-left">
      <h3 class="text-2xl font-serif text-stone-900 dark:text-white mb-8 flex items-center gap-4">
        <span class="w-12 h-[1px] bg-amber-600 block"></span>
        The Arsenal
      </h3>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {tools.map((tool) => (
          <div class="group relative overflow-hidden rounded-sm bg-zinc-900 border border-zinc-800 hover:border-amber-900/50 transition-colors aspect-[4/3] flex items-end shadow-lg">
            
            <img 
              src={tool.image} 
              alt={tool.name}
              class="absolute inset-0 w-full h-full object-cover grayscale opacity-80 dark:opacity-30 group-hover:grayscale-0 group-hover:opacity-50 transition-all duration-700 group-hover:scale-110"
            />
            
            <!-- Darker overlay for high contrast on tool names -->
            <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/80 to-transparent"></div>
            
            <div class="relative z-10 p-6 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500 w-full">
              <h4 class="text-lg font-serif text-white mb-1 drop-shadow-lg">
                {tool.name}
              </h4>
              <p class="text-xs text-amber-500 uppercase tracking-widest font-medium">
                {tool.role}
              </p>
            </div>

          </div>
        ))}
      </div>
    </div>
    
  </div>
</section>