---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---
<footer class="bg-zinc-950 pt-20 pb-10 border-t border-zinc-900 text-center relative z-20">
  <div class="max-w-4xl mx-auto px-6">
    
    <h2 class="text-2xl font-serif text-white tracking-[0.2em] mb-4">VENU</h2>
    
    <p class="text-zinc-500 text-sm font-light mb-10 max-w-sm mx-auto">
      Preserving life's grandest moments through the artistry of traditional photography and modern cinematic vision.
    </p>
    
    <div class="flex justify-center gap-8 mb-16 text-zinc-400 text-xs tracking-widest uppercase font-semibold">
      <a href="#" class="hover:text-amber-500 transition-colors">Instagram</a>
      <a href="#" class="hover:text-amber-500 transition-colors">Facebook</a>
      <a href="mailto:booking@venu.com" class="hover:text-amber-500 transition-colors">Email</a>
    </div>
    
    <div class="border-t border-zinc-900 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-zinc-600 tracking-wider">
      <p>&copy; {currentYear} Venu Photography. All Rights Reserved.</p>
      <p class="mt-4 md:mt-0">Designed for the Legacy.</p>
    </div>

  </div>
</footer>