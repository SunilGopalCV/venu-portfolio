---
// src/components/Hero.astro

// We will use 3 high-quality placeholder images representing traditional events.
// Later, you can swap these URLs with the photographer's best Cloudinary links.
const backgroundImages = [
  "https://images.squarespace-cdn.com/content/v1/6564afb4f0851760cfcdde58/d9a7e0f1-beef-4f16-ad02-1fefbdcae21e/Rajat-Raveena-2953.jpg?format=750w", // Elegant wedding rings/hands
  "https://images.squarespace-cdn.com/content/v1/6564afb4f0851760cfcdde58/796fcc79-1d68-4ff9-a502-58597c176f70/Saman-Hafiz-Nikkah-Chennai-0048.jpg?format=750w", // Traditional ceremony/attire
  "https://images.squarespace-cdn.com/content/v1/6564afb4f0851760cfcdde58/5674b282-7161-4ab2-82ec-08230161816a/Alok-Vidya-Wedding-Royal-Palms-0355.jpg?format=750w"  // Grand event setup
];
---

<section class="relative h-screen w-full overflow-hidden bg-zinc-950 flex items-center justify-center">
  
  <!-- Background Slideshow -->
  <div class="absolute inset-0 z-0 w-full h-full">
    {backgroundImages.map((img, index) => (
      <img 
        src={img} 
        alt="Cinematic Background" 
        class={`slideshow-image absolute inset-0 w-full h-full object-cover object-center`}
        style={`animation-delay: ${index * 8}s;`}
      />
    ))}
  </div>

  <!-- Gradient Overlays to ensure text is always readable -->
  <div class="absolute inset-0 z-10 bg-black/50 mix-blend-multiply"></div>
  <div class="absolute inset-0 z-10 bg-gradient-to-t from-zinc-950 via-zinc-950/20 to-black/40"></div>

  <!-- Content Foreground -->
  <div class="relative z-20 flex flex-col items-center justify-center text-center px-6 max-w-5xl mx-auto mt-20">
    
    <div class="overflow-hidden mb-6">
      <p class="text-amber-500/90 uppercase tracking-[0.3em] text-xs md:text-sm font-semibold animate-slide-up opacity-0" style="animation-fill-mode: forwards; animation-delay: 0.5s;">
        Over 20 Years of Excellence
      </p>
    </div>

    <div class="overflow-hidden mb-8">
      <h1 class="text-5xl md:text-7xl lg:text-8xl text-white font-serif tracking-tight drop-shadow-2xl animate-slide-up opacity-0" style="animation-fill-mode: forwards; animation-delay: 0.8s;">
        Timeless Traditions,<br/> 
        <span class="italic text-zinc-300 font-light">Cinematic Mastery.</span>
      </h1>
    </div>

    <div class="overflow-hidden">
      <p class="text-zinc-300 text-lg md:text-xl font-light max-w-2xl drop-shadow-md animate-slide-up opacity-0" style="animation-fill-mode: forwards; animation-delay: 1.1s;">
        Preserving life's grandest moments with the artistry of traditional photography and the precision of modern cinematic vision.
      </p>
    </div>

  </div>
</section>

<style>
  /* The "Ken Burns" fading slideshow effect */
  .slideshow-image {
    opacity: 0;
    transform: scale(1);
    /* 3 images * 8 seconds each = 24s total loop */
    animation: kenburns 24s infinite linear;
  }

  @keyframes kenburns {
    0% { opacity: 0; transform: scale(1); }
    10% { opacity: 1; }
    25% { opacity: 1; }
    35% { opacity: 0; transform: scale(1.1); }
    100% { opacity: 0; transform: scale(1.1); }
  }

  /* Text reveal animation */
  @keyframes slideUp {
    0% { opacity: 0; transform: translateY(40px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .animate-slide-up {
    animation: slideUp 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>